# Environment variables for AG Tutoring
# Copy this file to ".env" for local overrides, or set these in Vercel.
# Never put real secrets in a committed file. Only VITE_-prefixed vars are
# exposed to the browser, and they are PUBLIC once the site is built.

# Web3Forms access key for the contact form.
# This is a PUBLIC key (safe in client code). Optional: the app already
# ships with a working key hardcoded as a fallback. Set this only if you
# want to use a different key without editing the source.
# Get one at https://web3forms.com
VITE_WEB3FORMS_ACCESS_KEY=your-web3forms-access-key-here
